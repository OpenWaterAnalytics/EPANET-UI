object CurveEditorForm: TCurveEditorForm
  Left = 1300
  Height = 384
  Top = 400
  Width = 570
  BorderStyle = bsDialog
  Caption = 'Data Curve Selector'
  ClientHeight = 384
  ClientWidth = 570
  KeyPreview = True
  Position = poMainFormCenter
  LCLVersion = '4.4.0.0'
