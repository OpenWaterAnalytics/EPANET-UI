          83
          82
        )
      end
      object PreviewChart: TChart
        Left = 210
        Height = 248
        Top = 82
        Width = 350
        AntialiasingMode = amOn
        AxisList = <        
          item
            Grid.Color = clSilver
            Grid.Style = psSolid
            Marks.LabelFont.Height = -12
            Marks.LabelFont.Name = 'Noto Sans'
            Marks.LabelBrush.Style = bsClear
            Minors = <>
            Title.LabelFont.Height = -12
            Title.LabelFont.Name = 'Noto Sans'
            Title.LabelFont.Orientation = 900
            Title.Visible = True
            Title.LabelBrush.Style = bsClear
          end        
          item
            Grid.Visible = False
            Intervals.Options = [aipUseCount, aipUseNiceSteps]
            Alignment = calBottom
            Marks.LabelFont.Height = -12
            Marks.LabelFont.Name = 'Noto Sans'
            Marks.LabelBrush.Style = bsClear
            Minors = <>
            Title.LabelFont.Height = -12
            Title.LabelFont.Name = 'Noto Sans'
            Title.Visible = True
            Title.LabelBrush.Style = bsClear
          end>
        Foot.Brush.Color = clBtnFace
        Foot.Font.Color = clBlue
        Title.Brush.Color = clBtnFace
        Title.Font.Color = clBlue
        Title.Text.Strings = (
          'TAChart'
        )
        ParentColor = True
        object DataSeries1: TLineSeries
          LinePen.Color = clSkyBlue
          LinePen.Width = 4
          Pointer.Style = psCircle
          Pointer.Visible = True
          ShowPoints = True
