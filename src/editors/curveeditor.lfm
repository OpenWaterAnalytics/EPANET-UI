        ColCount = 3
        Columns = <        
          item
            Title.Caption = 'Name'
            Width = 120
          end        
          item
            Title.Caption = 'Type'
          end        
          item
            Title.Caption = 'Description'
            Width = 240
          end>
        FixedCols = 0
        Flat = True
        Options = [goFixedVertLine, goFixedHorzLine, goVertLine, goHorzLine, goRowSelect, goThumbTracking, goSmoothScroll]
